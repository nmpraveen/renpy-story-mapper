{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "m13-narrative-batch-response-v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "anyOf": [
          {"$ref": "#/$defs/success_item"},
          {"$ref": "#/$defs/refusal_item"}
        ]
      }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_class", "context_scope", "text", "evidence_handles", "child_claim_handles", "subject", "predicate", "polarity", "normalized_value"],
      "properties": {
        "claim_class": {"type": "string", "enum": ["factual", "interpretive", "review_suggestion"]},
        "context_scope": {"type": "string", "enum": ["atomic", "ordered_summary", "comparison"]},
        "text": {"type": "string", "minLength": 1, "maxLength": 1000},
        "evidence_handles": {
          "type": "array",
          "items": {"type": "string", "pattern": "^E[1-9][0-9]*$"}
        },
        "child_claim_handles": {
          "type": "array",
          "items": {"type": "string", "pattern": "^C[1-9][0-9]*$"}
        },
        "subject": {"type": "string", "minLength": 1, "maxLength": 320},
        "predicate": {"type": "string", "minLength": 1, "maxLength": 320},
        "polarity": {"type": "string", "enum": ["positive", "negative", "neutral"]},
        "normalized_value": {"type": "string", "minLength": 1, "maxLength": 320}
      }
    },
    "replacement_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ordinal", "claim_class", "context_scope", "text", "evidence_handles", "child_claim_handles", "subject", "predicate", "polarity", "normalized_value"],
      "properties": {
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 255},
        "claim_class": {"type": "string", "enum": ["factual", "interpretive", "review_suggestion"]},
        "context_scope": {"type": "string", "enum": ["atomic", "ordered_summary", "comparison"]},
        "text": {"type": "string", "minLength": 1, "maxLength": 1000},
        "evidence_handles": {
          "type": "array",
          "items": {"type": "string", "pattern": "^E[1-9][0-9]*$"}
        },
        "child_claim_handles": {
          "type": "array",
          "items": {"type": "string", "pattern": "^C[1-9][0-9]*$"}
        },
        "subject": {"type": "string", "minLength": 1, "maxLength": 320},
        "predicate": {"type": "string", "minLength": 1, "maxLength": 320},
        "polarity": {"type": "string", "enum": ["positive", "negative", "neutral"]},
        "normalized_value": {"type": "string", "minLength": 1, "maxLength": 320}
      }
    },
    "artifact_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_job_id", "title", "summary", "claims"],
      "properties": {
        "logical_job_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
        "claims": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {"$ref": "#/$defs/claim"}
        }
      }
    },
    "repair_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_job_id", "title", "summary", "claims"],
      "properties": {
        "logical_job_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
        "claims": {
          "type": "array",
          "maxItems": 256,
          "items": {"$ref": "#/$defs/replacement_claim"}
        }
      }
    },
    "success_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_job_id", "status", "payload", "error_code"],
      "properties": {
        "logical_job_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "status": {"type": "string", "const": "ok"},
        "payload": {
          "anyOf": [
            {"$ref": "#/$defs/artifact_payload"},
            {"$ref": "#/$defs/repair_payload"}
          ]
        },
        "error_code": {"type": "null"}
      }
    },
    "refusal_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_job_id", "status", "payload", "error_code"],
      "properties": {
        "logical_job_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "status": {"type": "string", "const": "content_refusal"},
        "payload": {"type": "null"},
        "error_code": {"type": "string", "const": "content_refusal"}
      }
    }
  }
}
