{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "m15-semantic-summary-v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["subject_kind", "subject_id", "membership_hash", "title", "summary", "characters", "claims", "warnings"],
  "properties": {
    "subject_kind": {"enum": ["beat", "major_cluster", "choice"]},
    "subject_id": {"type": "string", "minLength": 1},
    "membership_hash": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1, "maxLength": 80},
    "summary": {"type": "string", "minLength": 1, "maxLength": 600},
    "characters": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_class", "text", "evidence_ids"],
        "properties": {
          "claim_class": {"enum": ["factual", "interpretive"]},
          "text": {"type": "string", "minLength": 1, "maxLength": 600},
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    }
  }
}
