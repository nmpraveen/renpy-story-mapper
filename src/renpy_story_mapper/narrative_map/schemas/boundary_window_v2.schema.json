{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "m15-boundary-window-v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["window_id", "decisions"],
  "properties": {
    "window_id": {"type": "string", "minLength": 1},
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "decision", "reason", "confidence", "warnings"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "decision": {
            "enum": ["same_beat", "new_beat_same_cluster", "new_major_cluster", "uncertain"]
          },
          "reason": {"type": "string", "minLength": 1, "maxLength": 500},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "warnings": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 500}
          }
        }
      }
    }
  }
}
